# ============================================
# api-ia — Variáveis de Ambiente (exemplo)
# ============================================
# Copie este arquivo para .env e ajuste os valores.
# NÃO commite o .env real (deve estar no .gitignore).

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Provider default
PROVIDER_DEFAULT=local
PROVIDER_LOCAL_ENABLED=true
PROVIDER_ONLINE_ENABLED=false
PROVIDER_CORPORATE_ENABLED=false

# Online Provider (simulado — requer internet)
PROVIDER_ONLINE_BASE_URL=https://api.example.com/v1
PROVIDER_ONLINE_API_KEY=sk-exemplo-online-000

# Corporate Provider (simulado — ambiente interno)
PROVIDER_CORPORATE_BASE_URL=https://ia.corporate.internal/api/v1
PROVIDER_CORPORATE_API_KEY=corporate-api-key-exemplo

# SQL Server (read-only — placeholder)
SQL_SERVER=localhost
SQL_DATABASE=company_db
SQL_PORT=1433
SQL_USER=db_reader
SQL_PASSWORD=db_password_placeholder

# Agentes
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT_SECONDS=60